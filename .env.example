# Used for address-to-coordinate geocoding. Enable the Google Geocoding API
# for this key in Google Maps Platform.
GOOGLE_PLACES_API_KEY=your-google-maps-api-key-here

# OpenAI chat model configuration.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.4-nano
# Optional. Leave empty to reuse OPENAI_MODEL for the second hospital-selection call.
OPENAI_HOSPITAL_SELECTION_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.2
